# RPC variant (default)
RPC_URL=https://api.mainnet-beta.solana.com
# Optional: signature to stop the backfill at (older than this is excluded).
# UNTIL_SIGNATURE=4xK9j8CxiZ8tQyaFyN8wXtFzxwYL1QpLRf...c9Pq

# Helius GTFA variant — set this and swap variants::rpc(...) to
# variants::helius_gtfa(...) in src/main.rs.
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

RUST_LOG=info
