# Yellowstone variant (default)
GEYSER_URL=https://your-yellowstone-endpoint:443
X_TOKEN=your-auth-token

# LaserStream variant — set these and swap variants::yellowstone(...) to
# variants::laserstream(...) in src/main.rs.
# LASERSTREAM_URL=https://laserstream-mainnet-ewr.helius-rpc.com
# API_KEY=your-helius-api-key

# Jito Shredstream variant — set this and swap variants::yellowstone(...) to
# variants::jito_shredstream() in src/main.rs.
# JITO_SHREDSTREAM_URL=http://your-jito-shredstream-proxy:port

RUST_LOG=info
